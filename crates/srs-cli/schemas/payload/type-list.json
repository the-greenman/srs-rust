{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TypeListPayload",
  "type": "object",
  "required": [
    "types"
  ],
  "properties": {
    "types": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/TypeListEntry"
      }
    }
  },
  "definitions": {
    "TypeListEntry": {
      "description": "A single entry in a type list — the subset of `TypeSummary` exposed by the CLI. (Omits `description` which was never in the prior output.)",
      "type": "object",
      "required": [
        "fieldCount",
        "id",
        "name",
        "namespace",
        "version"
      ],
      "properties": {
        "fieldCount": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "sourcePackage": {
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    }
  }
}
