{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PackageListPayload",
  "type": "object",
  "required": [
    "packages"
  ],
  "properties": {
    "packages": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/PackageListEntry"
      }
    }
  },
  "definitions": {
    "PackageListEntry": {
      "description": "A single entry in a package list. Maps `PackageBoundaryInfo` with `boundary_path` renamed to `boundaryPath`.",
      "type": "object",
      "required": [
        "fieldCount",
        "id",
        "name",
        "namespace",
        "typeCount",
        "version"
      ],
      "properties": {
        "boundaryPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "fieldCount": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "typeCount": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "version": {
          "type": "string"
        }
      }
    }
  }
}
