{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FieldListPayload",
  "type": "object",
  "required": [
    "fields"
  ],
  "properties": {
    "fields": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/FieldListEntry"
      }
    }
  },
  "definitions": {
    "FieldListEntry": {
      "description": "A single entry in a field list — the subset of `FieldSummary` exposed by the CLI. (Omits `valueType` and `description` which were never in the prior output.)",
      "type": "object",
      "required": [
        "id",
        "name",
        "namespace",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "sourcePackage": {
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    }
  }
}
