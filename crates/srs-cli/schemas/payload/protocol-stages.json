{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProtocolStagesPayload",
  "type": "object",
  "required": [
    "stages"
  ],
  "properties": {
    "stages": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ProtocolStageEntry"
      }
    }
  },
  "definitions": {
    "FieldRef": {
      "description": "Payload mirror of `srs_core::types::protocol::FieldRef`. Separate struct because payload types must derive `JsonSchema`; srs-core must not depend on schemars (ADR-010).",
      "type": "object",
      "required": [
        "fieldId"
      ],
      "properties": {
        "fieldId": {
          "type": "string"
        },
        "typeId": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ProtocolStageEntry": {
      "description": "A single entry in a protocol stages list.",
      "type": "object",
      "required": [
        "dependsOn",
        "name",
        "order",
        "stageId"
      ],
      "properties": {
        "aiGuidance": true,
        "completionCriteria": {
          "type": [
            "string",
            "null"
          ]
        },
        "contributesTo": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/FieldRef"
          }
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "format": "int32"
        },
        "outputType": true,
        "purpose": {
          "type": [
            "string",
            "null"
          ]
        },
        "question": {
          "type": [
            "string",
            "null"
          ]
        },
        "stageId": {
          "type": "string"
        }
      }
    }
  }
}
