{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProtocolStagesPayload",
  "type": "object",
  "required": [
    "stages"
  ],
  "properties": {
    "stages": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ProtocolStageEntry"
      }
    }
  },
  "definitions": {
    "ProtocolStageEntry": {
      "description": "A single entry in a protocol stages list.",
      "type": "object",
      "required": [
        "dependsOn",
        "name",
        "order",
        "stageId"
      ],
      "properties": {
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "format": "int32"
        },
        "purpose": {
          "type": [
            "string",
            "null"
          ]
        },
        "stageId": {
          "type": "string"
        }
      }
    }
  }
}
