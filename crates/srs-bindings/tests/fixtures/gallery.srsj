    "records/tier-2/31291422-cd8b-4840-b884-d55023d938cb.json": {
      "createdAt": "2026-05-31T14:55:35.173940496+00:00",
      "fieldValues": [
        {
          "fieldId": "60be1468-01bc-5d12-9eea-628f02801893",
          "value": "A-002"
        },
        {
          "fieldId": "d7e82557-9045-5e92-a494-d99112bbec4a",
          "value": "What we are here to do"
        },
        {
          "fieldId": "8aa3eba2-204b-5ebd-ba7a-be0f066027d6",
          "value": "LiMoMa exists to curate, install, and maintain a rotating display of artwork in the back stairwell and landings of the building. We select work, agree on placement, and manage the practical business of mounting and demounting. We are not a commercial gallery: we do not sell work on behalf of artists, take commission, or enter into financial relationships with artists in exchange for showing their work."
        },
        {
          "fieldId": "3340532b-d845-5e54-92b3-819ed05365c5",
          "value": "Stating what we are not — a commercial gallery — is as important as stating what we are. This protects artists who exhibit with us and is honest about our amateur, community basis."
        },
        {
          "fieldId": "1f01bc6b-39c8-58d7-b1a3-79142623fece",
          "value": "Unanimous agreement of all current members."
        }
      ],
      "instanceId": "31291422-cd8b-4840-b884-d55023d938cb",
      "lifecycleState": "ratified",
      "typeId": "a1142ac3-5385-5c0e-8630-1dd3432cdf7f",
      "typeName": "article",
      "typeNamespace": "governance",
      "typeVersion": 1,
      "updatedAt": "2026-06-08T21:05:17.266092197+00:00"
    },
