    "records/tier-2/0482c489-37b4-4342-adaa-36e69dc6f780.json": {
      "createdAt": "2026-05-31T14:55:35.184158383+00:00",
      "fieldValues": [
        {
          "fieldId": "60be1468-01bc-5d12-9eea-628f02801893",
          "value": "A-004"
        },
        {
          "fieldId": "d7e82557-9045-5e92-a494-d99112bbec4a",
          "value": "How we make decisions"
        },
        {
          "fieldId": "8aa3eba2-204b-5ebd-ba7a-be0f066027d6",
          "value": "Decisions are made by talk and agreement. We do not vote. Where we cannot agree, the matter stays open or is recorded as an exercise. Once a decision is agreed, it is written down in the decision log and does not change silently — a new decision supersedes an old one by name. These Articles may be amended by unanimous agreement of all current members. The Clerk is responsible for maintaining the coherence of the record."
        },
        {
          "fieldId": "3340532b-d845-5e54-92b3-819ed05365c5",
          "value": "Writing things down is the mechanism by which we hold ourselves accountable and remain honest with artists who exhibit with us."
        },
        {
          "fieldId": "1f01bc6b-39c8-58d7-b1a3-79142623fece",
          "value": "Unanimous agreement of all current members."
        }
      ],
      "instanceId": "0482c489-37b4-4342-adaa-36e69dc6f780",
      "lifecycleState": "ratified",
      "typeId": "a1142ac3-5385-5c0e-8630-1dd3432cdf7f",
      "typeName": "article",
      "typeNamespace": "governance",
      "typeVersion": 1,
      "updatedAt": "2026-06-08T21:05:17.133891065+00:00"
    },
    "package/fields/alternativesconsidered-636ce948.json": {
      "aiGuidance": {
        "purpose": ""
      },
      "createdAt": "2026-05-25T00:00:00Z",
      "description": "Options that were considered but not chosen.",
      "id": "636ce948-2110-57b4-a3ed-04354ec17843",
      "name": "alternatives_considered",
      "namespace": "governance",
      "valueType": "text",
      "version": 1
    },
    "records/tier-2/7560efe9-27e3-4186-8b9d-6ab48283f1df.json": {
      "createdAt": "2026-05-31T14:55:35.178917705+00:00",
      "fieldValues": [
        {
          "fieldId": "60be1468-01bc-5d12-9eea-628f02801893",
          "value": "A-003"
        },
        {
          "fieldId": "d7e82557-9045-5e92-a494-d99112bbec4a",
          "value": "Who we are"
        },
        {
          "fieldId": "8aa3eba2-204b-5ebd-ba7a-be0f066027d6",
          "value": "The founding members of LiMoMa are Sam Hayder, Immo Klink, Peter Brownell, and Brian. New members may be admitted by agreement of all current members. Membership carries no financial obligation. Any member may resign at any time without formality. The group has no quorum rules during the pilot phase: decisions require that all members have had a reasonable opportunity to be heard."
        },
        {
          "fieldId": "1f01bc6b-39c8-58d7-b1a3-79142623fece",
          "value": "Unanimous agreement of all current members. Admission of a new member requires unanimous agreement."
        }
      ],
      "instanceId": "7560efe9-27e3-4186-8b9d-6ab48283f1df",
      "lifecycleState": "ratified",
      "typeId": "a1142ac3-5385-5c0e-8630-1dd3432cdf7f",
      "typeName": "article",
      "typeNamespace": "governance",
      "typeVersion": 1,
      "updatedAt": "2026-06-08T21:05:17.363275919+00:00"
    },
    "records/tier-2/4a989562-4a9d-4c86-a365-91bf14d55f06.json": {
      "createdAt": "2026-05-31T14:55:35.216705494+00:00",
      "fieldValues": [
        {
          "fieldId": "d7e82557-9045-5e92-a494-d99112bbec4a",
          "value": "Phase 1 scope"
        },
        {
          "fieldId": "73cd845a-3623-5bc6-8ade-42a7cd64740c",
          "value": "Should Phase 1 cover the full stairwell including the main hallway, or just the back stairs and landings?"
        },
        {
          "fieldId": "9889052c-9313-5e2f-a2ac-15baa3c6983e",
          "value": "The back stairs have a large amount of wall space across multiple landings. The main hallway was also discussed as a potential exhibition space, but adding it in Phase 1 would significantly increase the scope of the first experiment."
        },
        {
          "fieldId": "1a1c0a5d-a1df-5d03-95f2-32af73bb71da",
          "value": "Taking on too much in Phase 1 risks overextending the group's capacity before the mounting system and workflow have been tested."
        },
        {
          "fieldId": "636ce948-2110-57b4-a3ed-04354ec17843",
          "value": "Including the main hallway in Phase 1. Deferred to Phase 2."
        },
        {
          "fieldId": "de1296e0-e083-58d9-97a0-cb2b91fec02e",
          "value": "Phase 1 covers the back stairs and landings only. The main hallway is explicitly deferred to Phase 2, contingent on Phase 1 working well."
        },
        {
          "fieldId": "3340532b-d845-5e54-92b3-819ed05365c5",
          "value": "Starting smaller allows the group to test the mounting system, workflow, and artist relations before expanding. The main hallway is more visible and involves more parties."
        },
        {
          "fieldId": "c04b7f84-9a55-5353-8c9f-2b62f6a1e34e",
          "value": "December 2026 pilot review — if Phase 1 is working, bring main hallway into scope for Phase 2."
        }
      ],
      "instanceId": "4a989562-4a9d-4c86-a365-91bf14d55f06",
      "lifecycleState": "ratified",
      "typeId": "1fcad6a2-9f78-5e41-94ba-d82e88b822f3",
      "typeName": "decision",
      "typeNamespace": "governance",
      "typeVersion": 1,
      "updatedAt": "2026-06-08T21:05:17.881907273+00:00"
    },
