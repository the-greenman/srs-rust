  "data": {
    "records/tier-2/8ed62308-f7b4-47e1-b1a2-5490908efd86.json": {
      "createdAt": "2026-05-31T14:55:35.198208984+00:00",
      "fieldValues": [
        {
          "fieldId": "d7e82557-9045-5e92-a494-d99112bbec4a",
          "value": "R-002 Curatorial Lead"
        },
        {
          "fieldId": "a6c19b95-4f8f-5b07-93f8-3426c545277e",
          "value": "Immo Klink"
        },
        {
          "fieldId": "d25da548-79d6-555b-8878-f40b685b3955",
          "value": "May select which works are exhibited and which artists are invited to show during Phase 1. May decide placement and arrangement within the space, subject to Building Authority approval of any installation method. May set the thematic direction of a show."
        },
        {
          "fieldId": "3c39ee1f-6fe0-5da7-a0b6-928aa3a63211",
          "value": "Cannot approve installation methods or fixings — that is Building Authority. Cannot commit to showing work that would require structural changes not yet approved. Cannot enter financial agreements on behalf of the group."
        },
        {
          "fieldId": "9a32dc01-f348-5e05-9f54-bb6d21239f04",
          "value": "Delegated by the founding group at the founding meeting, May 2026. Role is Phase 1 scoped — to be reviewed at the pilot review in December 2026."
        },
        {
          "fieldId": "c04b7f84-9a55-5353-8c9f-2b62f6a1e34e",
          "value": "December 2026 pilot review."
        }
      ],
      "instanceId": "8ed62308-f7b4-47e1-b1a2-5490908efd86",
      "lifecycleState": "ratified",
      "typeId": "e53dce11-6b83-5714-a8fe-f730edb500fa",
      "typeName": "role",
      "typeNamespace": "governance",
      "typeVersion": 1,
      "updatedAt": "2026-06-08T21:05:18.757652487+00:00"
    },
