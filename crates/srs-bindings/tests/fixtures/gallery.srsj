    "records/tier-2/ad159754-2edd-4bf8-a70f-a29a617e5809.json": {
      "createdAt": "2026-05-31T14:55:35.167441369+00:00",
      "fieldValues": [
        {
          "fieldId": "60be1468-01bc-5d12-9eea-628f02801893",
          "value": "A-001"
        },
        {
          "fieldId": "d7e82557-9045-5e92-a494-d99112bbec4a",
          "value": "What this is"
        },
        {
          "fieldId": "8aa3eba2-204b-5ebd-ba7a-be0f066027d6",
          "value": "LiMoMa — the Limehouse Museum of Maybe Art — is a community gallery initiative that uses the back stairs and landings of Limehouse Town Hall as a space for exhibiting artwork. It exists as a voluntary association of members with no formal legal status. The pilot runs for six months from June 2026."
        },
        {
          "fieldId": "3340532b-d845-5e54-92b3-819ed05365c5",
          "value": "The name and definition set the frame for all subsequent decisions. 'Maybe Art' signals that the space is exploratory — not a conventional gallery with commercial or institutional expectations."
        },
        {
          "fieldId": "1f01bc6b-39c8-58d7-b1a3-79142623fece",
          "value": "Unanimous agreement of all current members."
        }
      ],
      "instanceId": "ad159754-2edd-4bf8-a70f-a29a617e5809",
      "lifecycleState": "ratified",
      "typeId": "a1142ac3-5385-5c0e-8630-1dd3432cdf7f",
      "typeName": "article",
      "typeNamespace": "governance",
      "typeVersion": 1,
      "updatedAt": "2026-06-08T21:05:17.461645865+00:00"
    },
    "package/document-views/articles-and-roles-78b11038.json": {
