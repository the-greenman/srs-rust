    "records/tier-2/ee000001-0000-4000-8000-000000000001.json": {
      "createdAt": "2026-06-27T00:00:00Z",
      "fieldValues": [
        {
          "fieldId": "d7e82557-9045-5e92-a494-d99112bbec4a",
          "value": "Pilot phase retrospective"
        },
        {
          "fieldId": "f1e00001-0000-4000-8000-000000000001",
          "value": "The group has reached a shared understanding that the pilot has demonstrated the space works for small group exhibitions. The hanging system is effective and the rotation schedule is sustainable."
        },
        {
          "fieldId": "f2e00002-0000-4000-8000-000000000002",
          "value": "Some members feel the decision-making process is slow. Others feel it is appropriately thorough for a shared space. There is tension between speed and careful deliberation."
        },
        {
          "fieldId": "f3e00003-0000-4000-8000-000000000003",
          "value": "What is the right frequency for exhibition rotation? Should we formalise the curatorial process for Phase 2?"
        },
        {
          "fieldId": "f4e00004-0000-4000-8000-000000000004",
          "value": "Agreement on Phase 2 scope is needed before we can plan the next exhibition cycle."
        },
        {
          "fieldId": "f5e00005-0000-4000-8000-000000000005",
          "value": "Clerk to circulate a Phase 2 proposal for comment by the end of July. All members to respond within two weeks."
        }
      ],
      "instanceId": "ee000001-0000-4000-8000-000000000001",
      "lifecycleState": "ratified",
      "typeId": "7f73b83e-4a5b-4c6d-8e9f-1a2b3c4d5e6f",
      "typeName": "exercise",
      "typeNamespace": "governance",
      "typeVersion": 1,
      "updatedAt": "2026-06-27T00:00:00Z"
    },
    "records/tier-2/ee000002-0000-4000-8000-000000000002.json": {
      "createdAt": "2026-06-27T00:00:00Z",
      "fieldValues": [
        {
          "fieldId": "d7e82557-9045-5e92-a494-d99112bbec4a",
          "value": "How do we make decisions when someone is absent?"
        },
        {
          "fieldId": "f1e00001-0000-4000-8000-000000000001",
          "value": "The group agrees that minor operational decisions can proceed with those present. Decisions that affect the constitutional articles or roles should wait for full attendance or use an asynchronous written consent process."
        },
        {
          "fieldId": "f2e00002-0000-4000-8000-000000000002",
          "value": "The group is divided on what counts as 'minor'. One member feels any decision on spending should require full attendance."
        },
        {
          "fieldId": "f3e00003-0000-4000-8000-000000000003",
          "value": "Where exactly is the threshold between operational and constitutional decisions? Should there be a spending threshold?"
        },
        {
          "fieldId": "f4e00004-0000-4000-8000-000000000004",
          "value": "None — the group can proceed on a provisional basis while the threshold question is worked out."
        },
        {
          "fieldId": "f5e00005-0000-4000-8000-000000000005",
          "value": "Building Authority to draft a proposed spending threshold for the next meeting."
        }
      ],
      "instanceId": "ee000002-0000-4000-8000-000000000002",
      "lifecycleState": "ratified",
      "typeId": "7f73b83e-4a5b-4c6d-8e9f-1a2b3c4d5e6f",
      "typeName": "exercise",
      "typeNamespace": "governance",
      "typeVersion": 1,
      "updatedAt": "2026-06-27T00:00:00Z"
    }
  }
}
